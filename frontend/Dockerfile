# Используем стабильную версию Node.js
FROM node:20-slim

WORKDIR /app

# Копируем файлы конфигурации npm
COPY package*.json ./

# Устанавливаем зависимости фронтенда
RUN npm install

# Копируем весь код фронтенда
COPY . .

# Открываем порт, который использует Vite (5173)
EXPOSE 5173

# Запускаем Vite с флагом --host, чтобы контейнер отдавал наружу интерфейс
CMD ["npm", "run", "dev", "--", "--host"]